c <- c + drop_x_title
e <- e + drop_x_title
f <- f + drop_x_title
h <- h + drop_x_title
i <- i + drop_x_title
# --- Remove y-axis titles for non-first column panels (histograms) ---
# b <- b + drop_y_title
